{
  "info": {
    "name": "Assetflow Odoo - Asset API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register Asset",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/assets",
          "host": [ "{{baseUrl}}" ],
          "path": [ "api", "assets" ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Dell XPS 13\",\n  \"serialNo\": \"SN-2024-001\",\n  \"categoryId\": \"category_id_here\",\n  \"acquisitionDate\": \"2024-01-15\",\n  \"cost\": 120000,\n  \"condition\": \"Excellent\",\n  \"location\": \"Mumbai Office - Floor 3\",\n  \"isBookable\": false,\n  \"departmentId\": \"dept_id_here\"\n}"
        }
      }
    },
    {
      "name": "Get All Assets (filters)",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": {
          "raw": "{{baseUrl}}/api/assets?search=XPS&status=AVAILABLE&page=1&limit=10",
          "host": [ "{{baseUrl}}" ],
          "path": [ "api", "assets" ],
          "query": [
            { "key": "search", "value": "XPS" },
            { "key": "status", "value": "AVAILABLE" },
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" }
          ]
        }
      }
    },
    {
      "name": "Get Asset by Tag",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": {
          "raw": "{{baseUrl}}/api/assets/tag/AF-0001",
          "host": [ "{{baseUrl}}" ],
          "path": [ "api", "assets", "tag", "AF-0001" ]
        }
      }
    },
    {
      "name": "Get Asset History",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": {
          "raw": "{{baseUrl}}/api/assets/history/{{assetId}}",
          "host": [ "{{baseUrl}}" ],
          "path": [ "api", "assets", "history", "{{assetId}}" ]
        }
      }
    },
    {
      "name": "Update Asset Status",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{asset_manager_token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/assets/{{assetId}}/status",
          "host": [ "{{baseUrl}}" ],
          "path": [ "api", "assets", "{{assetId}}", "status" ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"UNDER_MAINTENANCE\"\n}"
        }
      }
    }
    ,
    {
      "name": "Allocate Asset",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{asset_manager_token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/allocations/allocate",
          "host": [ "{{baseUrl}}" ],
          "path": [ "api", "allocations", "allocate" ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"assetId\": \"asset_id_here\",\n  \"employeeId\": \"employee_id_here\",\n  \"expectedReturn\": \"2024-12-31\",\n  \"notes\": \"Laptop for development work\"\n}"
        }
      }
    },
    {
      "name": "Request Transfer",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": {
          "raw": "{{baseUrl}}/api/allocations/transfer",
          "host": [ "{{baseUrl}}" ],
          "path": [ "api", "allocations", "transfer" ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"assetId\": \"asset_id_here\",\n  \"targetEmployeeId\": \"new_employee_id\",\n  \"reason\": \"Team restructuring\"\n}"
        }
      }
    },
    {
      "name": "Approve Transfer",
      "request": {
        "method": "PUT",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{asset_manager_token}}" } ],
        "url": {
          "raw": "{{baseUrl}}/api/allocations/transfer/{{allocationId}}",
          "host": [ "{{baseUrl}}" ],
          "path": [ "api", "allocations", "transfer", "{{allocationId}}" ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"action\": \"APPROVED\"\n}"
        }
      }
    },
    {
      "name": "Return Asset",
      "request": {
        "method": "PUT",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{asset_manager_token}}" } ],
        "url": {
          "raw": "{{baseUrl}}/api/allocations/return/{{assetId}}",
          "host": [ "{{baseUrl}}" ],
          "path": [ "api", "allocations", "return", "{{assetId}}" ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"condition\": \"Good\",\n  \"notes\": \"Laptop returned in working condition\"\n}"
        }
      }
    },
    {
      "name": "Get Overdue Allocations",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": {
          "raw": "{{baseUrl}}/api/allocations/overdue",
          "host": [ "{{baseUrl}}" ],
          "path": [ "api", "allocations", "overdue" ]
        }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "<token>" },
    { "key": "asset_manager_token", "value": "<asset_manager_token>" },
    { "key": "assetId", "value": "asset_id_here" }
  ]
}
